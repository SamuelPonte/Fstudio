@page "{id:int}"
@model GaleriaModel
@{
    ViewData["Title"] = $"Galeria - {Model.Cliente?.Nome}";
}

<div class="mb-4">
    <a asp-page="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Voltar
    </a>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-images me-2"></i>Galeria de @Model.Cliente?.Nome</h2>
        <p class="text-muted mb-0">Gerir fotografias da galeria privada do cliente</p>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Fotografias na Galeria</h5>
            </div>
            <div class="card-body">
                @if (Model.FotografiasCliente.Any())
                {
                    <div class="row g-3">
                        @foreach (var cf in Model.FotografiasCliente)
                        {
                            <div class="col-md-4 col-sm-6">
                                <div class="card h-100">
                                    <img src="@cf.Fotografia?.ThumbnailUrl" class="card-img-top"
                                         alt="@cf.Fotografia?.Titulo" style="height: 150px; object-fit: cover;" />
                                    <div class="card-body p-2">
                                        <small class="text-muted">@cf.Fotografia?.Titulo</small>
                                        @if (cf.Descarregada)
                                        {
                                            <span class="badge bg-success ms-1">Descarregada</span>
                                        }
                                    </div>
                                    <div class="card-footer p-2">
                                        <form method="post" asp-page-handler="RemoverFoto">
                                            <input type="hidden" name="clienteFotografiaId" value="@cf.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                                <i class="bi bi-x-lg me-1"></i>Remover
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-image fs-1"></i>
                        <p class="mt-2">Nenhuma fotografia na galeria.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Adicionar Fotografias</h5>
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="AdicionarFotos">
                    <div class="mb-3">
                        <label class="form-label">Selecionar Fotografias</label>
                        <select name="fotografiaIds" class="form-select" multiple size="10">
                            @foreach (var foto in Model.FotografiasDisponiveis)
                            {
                                <option value="@foto.Id">@foto.Titulo (@foto.Categoria?.Nome)</option>
                            }
                        </select>
                        <div class="form-text">Segure Ctrl para selecionar várias</div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-plus-lg me-2"></i>Adicionar Selecionadas
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

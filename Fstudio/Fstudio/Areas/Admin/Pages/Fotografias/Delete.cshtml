@page "{id:int}"
@model DeleteModel
@{
    ViewData["Title"] = "Eliminar Fotografia";
}

<div class="mb-4">
    <a asp-page="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Voltar
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Eliminar Fotografia</h5>
            </div>
            <div class="card-body">
                <p>Tem a certeza que deseja eliminar esta fotografia?</p>

                @if (!string.IsNullOrEmpty(Model.Fotografia?.ImagemUrl))
                {
                    <div class="mb-3">
                        <img src="@Model.Fotografia.ImagemUrl" alt="@Model.Fotografia.Titulo"
                             class="img-thumbnail" style="max-height: 200px;" />
                    </div>
                }

                <dl class="row mb-4">
                    <dt class="col-sm-4">Título</dt>
                    <dd class="col-sm-8">@Model.Fotografia?.Titulo</dd>

                    <dt class="col-sm-4">Categoria</dt>
                    <dd class="col-sm-8">@Model.Fotografia?.Categoria?.Nome</dd>
                </dl>

                <form method="post">
                    <input type="hidden" asp-for="Fotografia!.Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-2"></i>Eliminar
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

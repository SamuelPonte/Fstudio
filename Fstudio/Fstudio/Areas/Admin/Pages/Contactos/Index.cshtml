@page
@model IndexModel
@{
    ViewData["Title"] = "Contactos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-envelope me-2"></i>Contactos</h2>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Tipo Serviço</th>
                    <th>Data Envio</th>
                    <th>Estado</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contacto in Model.Contactos)
                {
                    <tr class="@(!contacto.Lido ? "table-warning" : "")">
                        <td>
                            @if (!contacto.Lido)
                            {
                                <i class="bi bi-circle-fill text-primary me-1" style="font-size: 0.5rem;"></i>
                            }
                            @contacto.Nome
                        </td>
                        <td>@contacto.Email</td>
                        <td>@contacto.TipoServico</td>
                        <td>
                            <time class="data-local"
                                  datetime="@DateTime.SpecifyKind(contacto.DataEnvio, DateTimeKind.Utc).ToString("o")">
                                @contacto.DataEnvio.ToString("dd/MM/yyyy HH:mm")
                            </time>
                        </td>
                        <td>
                            @if (contacto.Arquivado)
                            {
                                <span class="badge bg-secondary">Arquivado</span>
                            }
                            else if (contacto.Lido)
                            {
                                <span class="badge bg-success">Lido</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Novo</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-page="Details" asp-route-id="@contacto.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (!contacto.Arquivado)
                            {
                                <form method="post" asp-page-handler="Arquivar" asp-route-id="@contacto.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Arquivar">
                                        <i class="bi bi-archive"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Contactos.Any())
        {
            <div class="text-center py-4 text-muted">
                <i class="bi bi-envelope-open fs-1"></i>
                <p class="mt-2">Nenhum contacto encontrado.</p>
            </div>
        }
    </div>
</div>

<script>
    document.querySelectorAll(".data-local").forEach(function (elemento) {
        const dataUtc = new Date(elemento.getAttribute("datetime"));

        elemento.textContent = dataUtc.toLocaleString(undefined, {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
            hour: "2-digit",
            minute: "2-digit"
        });
    });
</script>

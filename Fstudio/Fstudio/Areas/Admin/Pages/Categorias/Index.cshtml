@page
@model IndexModel
@{
    ViewData["Title"] = "Categorias";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-folder me-2"></i>Categorias</h2>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>Nova Categoria
    </a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Slug</th>
                    <th>Ordem</th>
                    <th>Fotografias</th>
                    <th>Estado</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var categoria in Model.Categorias)
                {
                    <tr>
                        <td>@categoria.Nome</td>
                        <td><code>@categoria.Slug</code></td>
                        <td>@categoria.OrdemExibicao</td>
                        <td>@categoria.Fotografias.Count</td>
                        <td>
                            <span class="badge @(categoria.Activa ? "bg-success" : "bg-secondary")">
                                @(categoria.Activa ? "Activa" : "Inactiva")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-page="Edit" asp-route-id="@categoria.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-page="Delete" asp-route-id="@categoria.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Categorias.Any())
        {
            <div class="text-center py-4 text-muted">
                <i class="bi bi-folder2-open fs-1"></i>
                <p class="mt-2">Nenhuma categoria encontrada.</p>
            </div>
        }
    </div>
</div>

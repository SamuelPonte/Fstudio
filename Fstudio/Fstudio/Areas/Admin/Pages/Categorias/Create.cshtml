@page
@model CreateModel
@{
    ViewData["Title"] = "Nova Categoria";
}

<div class="mb-4">
    <a asp-page="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Voltar
    </a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-folder-plus me-2"></i>Nova Categoria</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Categoria.Nome" class="form-label"></label>
                        <input asp-for="Categoria.Nome" class="form-control" />
                        <span asp-validation-for="Categoria.Nome" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Categoria.Slug" class="form-label"></label>
                        <input asp-for="Categoria.Slug" class="form-control" />
                        <span asp-validation-for="Categoria.Slug" class="text-danger"></span>
                        <div class="form-text">Usado no URL (ex: casamentos, pre-casamento)</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Categoria.Descricao" class="form-label"></label>
                        <textarea asp-for="Categoria.Descricao" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Categoria.Descricao" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Categoria.OrdemExibicao" class="form-label"></label>
                            <input asp-for="Categoria.OrdemExibicao" type="number" class="form-control" />
                            <span asp-validation-for="Categoria.OrdemExibicao" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check mt-4">
                                <input asp-for="Categoria.Activa" class="form-check-input" />
                                <label asp-for="Categoria.Activa" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-2"></i>Criar Categoria
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

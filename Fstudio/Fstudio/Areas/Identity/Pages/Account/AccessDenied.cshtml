@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Acesso Negado";
}

<div class="page-header">
    <p class="section-subtitle">Oops!</p>
    <h1>Acesso Negado</h1>
    <div class="ornament">
        <i class="bi bi-shield-x"></i>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center animate-on-scroll">
                <p class="text-muted mb-4" style="font-size: 1.2rem;">
                    Não tem permissões para aceder a esta página.
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a asp-page="/Index" asp-area="" class="btn btn-artistic">
                        Voltar ao Início
                    </a>
                    <a asp-page="./Login" class="btn btn-outline-secondary">
                        Entrar com outra conta
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

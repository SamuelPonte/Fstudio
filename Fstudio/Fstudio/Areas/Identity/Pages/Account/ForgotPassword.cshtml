@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar Password";
}

<div class="page-header">
    <p class="section-subtitle">Área Privada</p>
    <h1>Recuperar Password</h1>
    <div class="ornament">
        <i class="bi bi-envelope-heart"></i>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                @if (Model.EmailEnviado)
                {
                    <!-- Mensagem de sucesso após submissão -->
                    <div class="card border-0 shadow-sm p-4 p-md-5 animate-on-scroll text-center" style="background: var(--bg-cream);">
                        <div class="mb-4" style="font-size: 3rem; color: var(--accent);">
                            <i class="bi bi-envelope-check"></i>
                        </div>
                        <h4 style="font-family: 'Cormorant Garamond', serif;">Pedido recebido</h4>
                        <p class="text-muted mt-3">
                            Se o endereço de email indicado estiver registado, receberá em breve um email com instruções para repor a sua password.
                        </p>
                        <p class="text-muted small mt-2">
                            Não recebeu o email? Verifique a pasta de spam ou
                            <a asp-page="./ForgotPassword" style="color: var(--accent);">tente novamente</a>.
                        </p>
                        <div class="mt-4">
                            <a asp-page="./Login" class="btn btn-artistic px-4">
                                Voltar ao Login
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Formulário de pedido de recuperação de password -->
                    <div class="card border-0 shadow-sm p-4 p-md-5 animate-on-scroll" style="background: var(--bg-cream);">
                        <p class="text-muted mb-4" style="font-family: 'Cormorant Garamond', serif; font-size: 1.1rem;">
                            Indique o email associado à sua conta e enviaremos um link para repor a sua password.
                        </p>

                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                            <div class="mb-4">
                                <label asp-for="Input.Email" class="form-label" style="font-family: 'Cormorant Garamond', serif; font-size: 1.1rem;">Email</label>
                                <input asp-for="Input.Email"
                                       class="form-control form-control-lg border-0 border-bottom rounded-0"
                                       style="background: transparent;"
                                       placeholder="email@exemplo.com"
                                       autocomplete="email" />
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="text-center mt-5">
                                <button type="submit" class="btn btn-artistic px-5 py-3 w-100">
                                    Enviar Link de Recuperação
                                </button>
                            </div>

                            <div class="text-center mt-4">
                                <a asp-page="./Login" style="color: var(--accent);" class="small">
                                    <i class="bi bi-arrow-left me-1"></i>Voltar ao Login
                                </a>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

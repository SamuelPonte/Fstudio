<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fstudio Cliente</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Great+Vibes&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-light: #fefefe;
            --bg-cream: #faf8f5;
            --text-dark: #2c2c2c;
            --text-muted: #6b6b6b;
            --accent: #c4a35a;
            --accent-dark: #a08642;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        h1, h2, h3, h4, h5 {
            font-family: 'Cormorant Garamond', serif;
            font-weight: 400;
        }

        .script-font {
            font-family: 'Great Vibes', cursive;
        }

        /* Navbar */
        .navbar-cliente {
            background: var(--bg-cream);
            padding: 1.5rem 0;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .navbar-cliente .navbar-brand {
            font-family: 'Great Vibes', cursive;
            font-size: 2rem;
            color: var(--text-dark);
        }

        .navbar-cliente .nav-link {
            font-family: 'Montserrat', sans-serif;
            color: var(--text-dark);
            font-size: 0.85rem;
            letter-spacing: 1px;
            padding: 0.5rem 1rem;
            transition: color 0.3s;
        }

        .navbar-cliente .nav-link:hover {
            color: var(--accent);
        }

        .navbar-toggler {
            border-color: var(--accent);
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='%23c4a35a' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        /* Page Header */
        .page-header-cliente {
            background: var(--bg-cream);
            padding: 3rem 0;
            text-align: center;
            margin-bottom: 2rem;
        }

        .page-header-cliente h1 {
            font-family: 'Great Vibes', cursive;
            font-size: 3rem;
            color: var(--text-dark);
        }

        /* Welcome Section */
        .welcome-section {
            background: var(--bg-cream);
            padding: 3rem;
            border-radius: 0.5rem;
            margin-bottom: 2rem;
            text-align: center;
        }

        .welcome-section h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.5rem;
        }

        /* Cards */
        .card-foto {
            background: #fff;
            border: none;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            transition: transform 0.3s, box-shadow 0.3s;
            overflow: hidden;
        }

        .card-foto:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        }

        .card-foto img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .card-foto .card-body {
            padding: 1rem;
        }

        .card-foto .card-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.1rem;
            color: var(--text-dark);
        }

        /* Buttons */
        .btn-download {
            background: var(--accent);
            color: #fff;
            border: none;
            padding: 0.75rem 1.5rem;
            letter-spacing: 1px;
            font-size: 0.85rem;
            transition: all 0.3s;
        }

        .btn-download:hover {
            background: var(--accent-dark);
            color: #fff;
        }

        .btn-outline-accent {
            border: 1px solid var(--accent);
            color: var(--accent);
            background: transparent;
        }

        .btn-outline-accent:hover {
            background: var(--accent);
            color: #fff;
        }

        .btn-artistic {
            background: transparent;
            border: 1px solid var(--text-dark);
            color: var(--text-dark);
            padding: 0.75rem 2rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-size: 0.75rem;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .btn-artistic::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: var(--accent);
            transition: left 0.4s ease;
            z-index: -1;
        }

        .btn-artistic:hover {
            border-color: var(--accent);
            color: #fff;
        }

        .btn-artistic:hover::before {
            left: 0;
        }

        .text-accent {
            color: var(--accent) !important;
        }

        /* Ornament */
        .ornament {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            margin: 1.5rem 0;
        }

        .ornament::before,
        .ornament::after {
            content: '';
            width: 50px;
            height: 1px;
            background: var(--accent);
        }

        .ornament i {
            color: var(--accent);
            font-size: 0.8rem;
        }

        /* Footer */
        .footer-cliente {
            background: var(--bg-cream);
            padding: 2rem 0;
            margin-top: auto;
            text-align: center;
        }

        .footer-cliente .footer-brand {
            font-family: 'Great Vibes', cursive;
            font-size: 1.8rem;
            color: var(--text-dark);
        }

        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
        }

        .empty-state i {
            font-size: 5rem;
            color: var(--accent);
            opacity: 0.5;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-cliente">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-page="/Index">Fstudio</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Cliente" asp-page="/Index">
                            <i class="bi bi-images me-1"></i> Minha Galeria
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-page="/Index">
                            <i class="bi bi-globe me-1"></i> Ver Site
                        </a>
                    </li>
                    <li class="nav-item ms-2">
                        <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-accent btn-sm">
                                <i class="bi bi-box-arrow-right me-1"></i> Sair
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        @RenderBody()
    </main>

    <footer class="footer-cliente">
        <div class="container">
            <p class="footer-brand mb-2">Fstudio</p>
            <p class="text-muted small mb-0">&copy; @DateTime.Now.Year Fstudio Wedding Photography</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>

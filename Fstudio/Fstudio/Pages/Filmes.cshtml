@page
@model FilmesModel
@{
    ViewData["Title"] = "Filmes";
}

<div class="page-header">
    <p class="section-subtitle">Filmes</p>
    <h1>Filmes de Casamento</h1>
    <div class="ornament">
        <i class="bi bi-film"></i>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-lg-8 text-center animate-on-scroll">
                <p class="text-muted" style="font-size: 1.2rem; line-height: 1.9;">
                    Além da fotografia, oferecemos filmes de casamento cinematográficos que capturam
                    a emoção, os votos, as lágrimas de alegria e todas as danças da noite. Um filme
                    que vão querer ver vezes sem conta.
                </p>
            </div>
        </div>

        <!-- Video Samples -->
        <div class="row g-4 mb-5">
            <div class="col-md-6 animate-on-scroll animate-delay-1">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="ratio ratio-16x9">
                        <img src="https://images.unsplash.com/photo-1519741497674-611481863552?w=800" alt="Video placeholder" style="object-fit: cover;" />
                        <div class="d-flex align-items-center justify-content-center" style="background: rgba(0,0,0,0.3); position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
                            <i class="bi bi-play-circle-fill" style="font-size: 4rem; color: white; opacity: 0.9;"></i>
                        </div>
                    </div>
                    <div class="card-body text-center" style="background: var(--bg-cream);">
                        <h5 style="font-family: 'Cormorant Garamond', serif;">Ana & João</h5>
                        <p class="text-muted small mb-0">Casamento na Quinta das Lágrimas</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 animate-on-scroll animate-delay-2">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="ratio ratio-16x9">
                        <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=800" alt="Video placeholder" style="object-fit: cover;" />
                        <div class="d-flex align-items-center justify-content-center" style="background: rgba(0,0,0,0.3); position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
                            <i class="bi bi-play-circle-fill" style="font-size: 4rem; color: white; opacity: 0.9;"></i>
                        </div>
                    </div>
                    <div class="card-body text-center" style="background: var(--bg-cream);">
                        <h5 style="font-family: 'Cormorant Garamond', serif;">Sofia & Pedro</h5>
                        <p class="text-muted small mb-0">Casamento na Serra da Arrábida</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-6 animate-on-scroll animate-delay-3">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="ratio ratio-16x9">
                        <img src="https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=800" alt="Video placeholder" style="object-fit: cover;" />
                        <div class="d-flex align-items-center justify-content-center" style="background: rgba(0,0,0,0.3); position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
                            <i class="bi bi-play-circle-fill" style="font-size: 4rem; color: white; opacity: 0.9;"></i>
                        </div>
                    </div>
                    <div class="card-body text-center" style="background: var(--bg-cream);">
                        <h5 style="font-family: 'Cormorant Garamond', serif;">Maria & Tiago</h5>
                        <p class="text-muted small mb-0">Pré-Casamento no Douro</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 animate-on-scroll animate-delay-4">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="ratio ratio-16x9">
                        <img src="https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=800" alt="Video placeholder" style="object-fit: cover;" />
                        <div class="d-flex align-items-center justify-content-center" style="background: rgba(0,0,0,0.3); position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
                            <i class="bi bi-play-circle-fill" style="font-size: 4rem; color: white; opacity: 0.9;"></i>
                        </div>
                    </div>
                    <div class="card-body text-center" style="background: var(--bg-cream);">
                        <h5 style="font-family: 'Cormorant Garamond', serif;">Inês & Miguel</h5>
                        <p class="text-muted small mb-0">Casamento em Sintra</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Video Packages -->
<section class="section section-cream">
    <div class="container">
        <div class="text-center mb-5 animate-on-scroll">
            <p class="section-subtitle">Pacotes</p>
            <h2 class="section-title">Opções de Vídeo</h2>
            <div class="ornament">
                <i class="bi bi-camera-reels"></i>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="row g-4">
                    <div class="col-md-4 animate-on-scroll animate-delay-1">
                        <div class="card border-0 shadow-sm h-100 text-center p-4" style="background: white;">
                            <div class="card-body">
                                <i class="bi bi-play-btn" style="font-size: 3rem; color: var(--accent);"></i>
                                <h4 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Highlight</h4>
                                <p class="text-muted mb-4">Filme de 3-5 minutos com os melhores momentos do vosso dia, editado com música da vossa escolha.</p>
                                <ul class="list-unstyled text-muted small">
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>3-5 minutos</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Full HD</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Música licenciada</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 animate-on-scroll animate-delay-2">
                        <div class="card border-0 shadow-sm h-100 text-center p-4" style="background: white; border: 2px solid var(--accent) !important;">
                            <div class="card-body">
                                <span class="badge mb-3" style="background: var(--accent);">Mais Popular</span>
                                <i class="bi bi-collection-play" style="font-size: 3rem; color: var(--accent);"></i>
                                <h4 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Documentário</h4>
                                <p class="text-muted mb-4">Filme de 15-20 minutos com a história completa do dia, incluindo áudio da cerimónia.</p>
                                <ul class="list-unstyled text-muted small">
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>15-20 minutos</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>4K Ultra HD</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Áudio da cerimónia</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Entrevistas opcionais</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 animate-on-scroll animate-delay-3">
                        <div class="card border-0 shadow-sm h-100 text-center p-4" style="background: white;">
                            <div class="card-body">
                                <i class="bi bi-film" style="font-size: 3rem; color: var(--accent);"></i>
                                <h4 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Completo</h4>
                                <p class="text-muted mb-4">Pacote completo com Highlight, Documentário e cerimónia integral gravada.</p>
                                <ul class="list-unstyled text-muted small">
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Highlight + Documentário</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Cerimónia integral</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>4K Ultra HD</li>
                                    <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Drone (se permitido)</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Process -->
<section class="section">
    <div class="container">
        <div class="text-center mb-5 animate-on-scroll">
            <p class="section-subtitle">Processo</p>
            <h2 class="section-title">Como Trabalhamos</h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="row">
                    <div class="col-md-3 text-center mb-4 animate-on-scroll animate-delay-1">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                             style="width: 80px; height: 80px; background: var(--bg-cream);">
                            <span class="script-font" style="font-size: 2rem; color: var(--accent);">1</span>
                        </div>
                        <h5 style="font-family: 'Cormorant Garamond', serif;">Reunião</h5>
                        <p class="text-muted small">Conhecemos-vos e discutimos a vossa visão para o filme.</p>
                    </div>
                    <div class="col-md-3 text-center mb-4 animate-on-scroll animate-delay-2">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                             style="width: 80px; height: 80px; background: var(--bg-cream);">
                            <span class="script-font" style="font-size: 2rem; color: var(--accent);">2</span>
                        </div>
                        <h5 style="font-family: 'Cormorant Garamond', serif;">Filmagem</h5>
                        <p class="text-muted small">Capturamos cada momento especial com equipamento cinematográfico.</p>
                    </div>
                    <div class="col-md-3 text-center mb-4 animate-on-scroll animate-delay-3">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                             style="width: 80px; height: 80px; background: var(--bg-cream);">
                            <span class="script-font" style="font-size: 2rem; color: var(--accent);">3</span>
                        </div>
                        <h5 style="font-family: 'Cormorant Garamond', serif;">Edição</h5>
                        <p class="text-muted small">Criamos um filme único com correção de cor e som profissional.</p>
                    </div>
                    <div class="col-md-3 text-center mb-4 animate-on-scroll animate-delay-4">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                             style="width: 80px; height: 80px; background: var(--bg-cream);">
                            <span class="script-font" style="font-size: 2rem; color: var(--accent);">4</span>
                        </div>
                        <h5 style="font-family: 'Cormorant Garamond', serif;">Entrega</h5>
                        <p class="text-muted small">Recebem o filme em alta resolução para guardar para sempre.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section section-cream text-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 animate-on-scroll">
                <p class="section-subtitle" style="font-size: 2rem;">Querem um filme?</p>
                <h2 class="section-title">Vamos Criar a Vossa História em Movimento</h2>
                <p class="text-muted my-4">
                    Combinem fotografia e vídeo para uma cobertura completa do vosso dia especial.
                </p>
                <a asp-page="/Contacto" class="btn btn-artistic">Pedir Orçamento</a>
            </div>
        </div>
    </div>
</section>

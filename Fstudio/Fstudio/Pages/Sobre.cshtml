@page
@model SobreModel
@{
    ViewData["Title"] = "Sobre";
}

<div class="page-header">
    <p class="section-subtitle">Sobre Nós</p>
    <h1>A Nossa História</h1>
    <div class="ornament">
        <i class="bi bi-heart-fill"></i>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0 animate-on-scroll">
                <div class="about-image">
                    <img src="https://images.unsplash.com/photo-1554048612-b6a482bc67e5?w=800" alt="Fotógrafo" />
                </div>
            </div>
            <div class="col-lg-6 ps-lg-5">
                <div class="animate-on-scroll animate-delay-2">
                    <p class="section-subtitle text-start">Quem Somos</p>
                    <h2 class="section-title text-start" style="font-size: 2.5rem;">Elisa, Luís e André Vassalo</h2>
                </div>
                <p class="text-muted my-4 animate-on-scroll animate-delay-3" style="line-height: 1.9;">
                    Somos a Elisa, o Luís e o André Vassalo — uma equipa de fotógrafos sediada em Tomar,
                    apaixonada por contar histórias de amor através das nossas câmaras.
                    A fotografia de casamentos não é apenas o nosso trabalho — é a nossa paixão.
                </p>
                <p class="text-muted mb-4 animate-on-scroll animate-delay-4" style="line-height: 1.9;">
                    Cada casamento é único, e o nosso objetivo é contar a vossa história de uma forma autêntica
                    e intemporal. Acreditamos que as melhores fotografias surgem quando os casais se sentem
                    confortáveis e relaxados, por isso fazemos questão de criar um ambiente descontraído.
                </p>
                <p class="text-muted animate-on-scroll animate-delay-5" style="line-height: 1.9;">
                    O nosso estilo combina fotojornalismo documental com retratos artísticos, capturando tanto
                    os grandes momentos como os pequenos detalhes que tornam o vosso dia especial.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="section section-cream">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3 mb-4 animate-on-scroll animate-delay-1">
                <p class="script-font" style="font-size: 3.5rem; color: var(--accent); margin-bottom: 0;">500+</p>
                <p class="text-muted" style="font-family: 'Cormorant Garamond', serif; font-size: 1.1rem;">Casamentos Fotografados</p>
            </div>
            <div class="col-md-3 mb-4 animate-on-scroll animate-delay-2">
                <p class="script-font" style="font-size: 3.5rem; color: var(--accent); margin-bottom: 0;">10+</p>
                <p class="text-muted" style="font-family: 'Cormorant Garamond', serif; font-size: 1.1rem;">Anos de Experiência</p>
            </div>
            <div class="col-md-3 mb-4 animate-on-scroll animate-delay-3">
                <p class="script-font" style="font-size: 3.5rem; color: var(--accent); margin-bottom: 0;">100%</p>
                <p class="text-muted" style="font-family: 'Cormorant Garamond', serif; font-size: 1.1rem;">Clientes Satisfeitos</p>
            </div>
            <div class="col-md-3 mb-4 animate-on-scroll animate-delay-4">
                <p class="script-font" style="font-size: 3.5rem; color: var(--accent); margin-bottom: 0;">15</p>
                <p class="text-muted" style="font-family: 'Cormorant Garamond', serif; font-size: 1.1rem;">Prémios Ganhos</p>
            </div>
        </div>
    </div>
</section>

<!-- Philosophy Section -->
<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center animate-on-scroll">
                <p class="section-subtitle">Filosofia</p>
                <h2 class="section-title">A Nossa Abordagem</h2>
                <div class="ornament">
                    <i class="bi bi-camera"></i>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-md-4 mb-4 animate-on-scroll animate-delay-1">
                <div class="text-center p-4">
                    <i class="bi bi-eye" style="font-size: 3rem; color: var(--accent);"></i>
                    <h4 class="mt-4" style="font-family: 'Cormorant Garamond', serif; font-weight: 400;">Observar</h4>
                    <p class="text-muted small">Capturar momentos genuínos sem interferir, deixando a magia acontecer naturalmente.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4 animate-on-scroll animate-delay-2">
                <div class="text-center p-4">
                    <i class="bi bi-palette" style="font-size: 3rem; color: var(--accent);"></i>
                    <h4 class="mt-4" style="font-family: 'Cormorant Garamond', serif; font-weight: 400;">Criar</h4>
                    <p class="text-muted small">Transformar cada imagem numa obra de arte com edição cuidada e atemporal.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4 animate-on-scroll animate-delay-3">
                <div class="text-center p-4">
                    <i class="bi bi-heart" style="font-size: 3rem; color: var(--accent);"></i>
                    <h4 class="mt-4" style="font-family: 'Cormorant Garamond', serif; font-weight: 400;">Sentir</h4>
                    <p class="text-muted small">Preservar as emoções e sentimentos que tornam cada casamento único.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Behind the Scenes -->
<section class="parallax-section py-5" style="background-image: linear-gradient(rgba(255,255,255,0.9), rgba(255,255,255,0.9)), url('https://images.unsplash.com/photo-1537633552985-df8429e8048b?w=1920');">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6 animate-on-scroll">
                <img src="https://images.unsplash.com/photo-1492691527719-9d1e07e534b4?w=600" alt="Equipamento" class="img-fluid rounded shadow" />
            </div>
            <div class="col-lg-6 ps-lg-5 mt-4 mt-lg-0">
                <div class="animate-on-scroll animate-delay-2">
                    <p class="section-subtitle text-start">Equipamento</p>
                    <h3 style="font-family: 'Cormorant Garamond', serif;">Por Trás da Câmara</h3>
                    <p class="text-muted mt-3" style="line-height: 1.9;">
                        Utilizamos equipamento profissional de última geração para garantir a melhor qualidade em todas as condições.
                        Câmaras full-frame, objetivas luminosas e backup completo asseguram que nenhum momento é perdido.
                    </p>
                    <p class="text-muted" style="line-height: 1.9;">
                        A nossa equipa de três fotógrafos permite capturar perspetivas únicas em simultâneo
                        e garantir cobertura total do vosso dia especial.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section section-cream text-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 animate-on-scroll">
                <p class="section-subtitle" style="font-size: 2rem;">Prontos para começar?</p>
                <h2 class="section-title">Vamos Conversar</h2>
                <p class="text-muted my-4">
                    Estamos ansiosos por conhecer a vossa história e ajudar a preservar as memórias do vosso dia especial.
                </p>
                <a asp-page="/Contacto" class="btn btn-artistic">Entrar em Contacto</a>
            </div>
        </div>
    </div>
</section>

@page
@model IndexModel
@{
    ViewData["Title"] = "Portfólio";
}

<div class="page-header">
    <p class="section-subtitle">Portfólio</p>
    <h1>Os Nossos Trabalhos</h1>
    <div class="ornament">
        <i class="bi bi-camera"></i>
    </div>
</div>

<div class="container pb-5">
    <div class="d-flex justify-content-center flex-wrap gap-3 mt-5 mb-5 animate-on-scroll">
        <a asp-page="/Portfolio/Index"
           class="btn d-inline-flex align-items-center @(string.IsNullOrEmpty(Model.CategoriaSlug) ? "btn-artistic" : "btn-outline-secondary")"
           style="@(string.IsNullOrEmpty(Model.CategoriaSlug) ? "" : "border-color: #ccc;")">
            Todos
        </a>
        @foreach (var categoria in Model.Categorias)
        {
            <a asp-page="/Portfolio/Index" asp-route-categoria="@categoria.Slug"
               class="btn d-inline-flex align-items-center @(Model.CategoriaSlug == categoria.Slug ? "btn-artistic" : "btn-outline-secondary")"
               style="@(Model.CategoriaSlug == categoria.Slug ? "" : "border-color: #ccc;")">
                @categoria.Nome
            </a>
        }
    </div>

    @if (!Model.Fotografias.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted">Não existem fotografias disponíveis nesta categoria.</p>
        </div>
    }
    else
    {
        <div class="portfolio-grid">
            @foreach (var item in Model.Fotografias.Select((fotografia, index) => new { fotografia, index }))
            {
                <div class="portfolio-item animate-on-scroll animate-delay-@((item.index % 6) + 1)">
                    <img src="@item.fotografia.ImagemUrl"
                         alt="@item.fotografia.Titulo"
                         loading="lazy" />

                    <div class="overlay">
                        <h5>@item.fotografia.Titulo</h5>
                        <span>@item.fotografia.Categoria?.Nome</span>
                    </div>
                </div>
            }
        </div>
    }

    <div class="text-center mt-5 animate-on-scroll">
        <p class="text-muted mb-4">Quer ver mais trabalhos? Entre em contacto para uma sessão personalizada.</p>
        <a asp-page="/Contacto" class="btn btn-artistic">Contactar</a>
    </div>
</div>

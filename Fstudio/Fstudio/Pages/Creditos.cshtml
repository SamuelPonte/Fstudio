@page
@model CreditosModel
@{
    ViewData["Title"] = "Créditos";
}

<div class="page-header">
    <p class="section-subtitle">Créditos</p>
    <h1>Reconhecimentos</h1>
    <div class="ornament">
        <i class="bi bi-award"></i>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <!-- Informações académicas -->
                <div class="card border-0 shadow-sm p-4 p-md-5 mb-4 animate-on-scroll" style="background: var(--bg-cream);">
                    <div class="text-center mb-4">
                        <i class="bi bi-mortarboard" style="font-size: 2.5rem; color: var(--accent);"></i>
                        <h3 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Informações Académicas</h3>
                    </div>

                    <ul class="list-unstyled text-center text-muted mb-0">
                        <li class="mb-2">
                            <strong>Curso:</strong> Engenharia Informática
                        </li>
                        <li class="mb-2">
                            <strong>Disciplina:</strong> Desenvolvimento Web
                        </li>
                        <li>
                            <strong>Ano letivo:</strong> 2025/2026
                        </li>
                    </ul>
                </div>

                <!-- Autores e docentes -->
                <div class="card border-0 shadow-sm p-4 p-md-5 mb-4 animate-on-scroll animate-delay-1" style="background: var(--bg-cream);">
                    <div class="text-center mb-4">
                        <i class="bi bi-people" style="font-size: 2.5rem; color: var(--accent);"></i>
                        <h3 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Autores e Docentes</h3>
                    </div>

                    <div class="text-center text-muted">
                        <p class="mb-2">
                            <strong>N.º 27227</strong> — Samuel Ramos Da Ponte
                        </p>
                        <p class="mb-4">
                            <strong>N.º 27454</strong> — André Miguel Vassalo Carvalho
                        </p>

                        <p class="mb-1">
                            <strong>Docentes:</strong>
                        </p>
                        <p class="mb-0">
                            José Casimiro Pereira e João Filipe Rodrigues Silva
                        </p>
                    </div>
                </div>

                <!-- Credenciais de teste -->
                <div class="card border-0 shadow-sm p-4 p-md-5 mb-4 animate-on-scroll animate-delay-2" style="background: var(--bg-cream);">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-lock" style="font-size: 2.5rem; color: var(--accent);"></i>
                        <h3 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Credenciais de Teste</h3>
                    </div>

                    <p class="text-muted text-center">
                        Para efeitos de avaliação e demonstração da aplicação, foram criados os seguintes utilizadores de teste:
                    </p>

                    <div class="table-responsive">
                        <table class="table table-borderless align-middle text-muted mb-0">
                            <thead>
                                <tr>
                                    <th>Perfil</th>
                                    <th>Email</th>
                                    <th>Password</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Administrador</td>
                                    <td>admin@fstudio.info</td>
                                    <td>Admin123!</td>
                                </tr>
                                <tr>
                                    <td>Cliente</td>
                                    <td>cliente@demo.com</td>
                                    <td>Cliente123!</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Tecnologias utilizadas -->
                <div class="card border-0 shadow-sm p-4 p-md-5 mb-4 animate-on-scroll" style="background: var(--bg-cream);">
                    <div class="text-center mb-4">
                        <i class="bi bi-code-slash" style="font-size: 2.5rem; color: var(--accent);"></i>
                        <h3 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Tecnologias Utilizadas</h3>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-3 d-flex align-items-center">
                                    <i class="bi bi-check-circle-fill me-3" style="color: var(--accent);"></i>
                                    <span class="text-muted">ASP.NET Core 10.0</span>
                                </li>
                                <li class="mb-3 d-flex align-items-center">
                                    <i class="bi bi-check-circle-fill me-3" style="color: var(--accent);"></i>
                                    <span class="text-muted">ASP.NET Core Razor Pages</span>
                                </li>
                                <li class="mb-3 d-flex align-items-center">
                                    <i class="bi bi-check-circle-fill me-3" style="color: var(--accent);"></i>
                                    <span class="text-muted">Entity Framework Core</span>
                                </li>
                                <li class="mb-3 d-flex align-items-center">
                                    <i class="bi bi-check-circle-fill me-3" style="color: var(--accent);"></i>
                                    <span class="text-muted">LINQ</span>
                                </li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-3 d-flex align-items-center">
                                    <i class="bi bi-check-circle-fill me-3" style="color: var(--accent);"></i>
                                    <span class="text-muted">SignalR</span>
                                </li>
                                <li class="mb-3 d-flex align-items-center">
                                    <i class="bi bi-check-circle-fill me-3" style="color: var(--accent);"></i>
                                    <span class="text-muted">Bootstrap 5</span>
                                </li>
                                <li class="mb-3 d-flex align-items-center">
                                    <i class="bi bi-check-circle-fill me-3" style="color: var(--accent);"></i>
                                    <span class="text-muted">Bootstrap Icons</span>
                                </li>
                                <li class="mb-3 d-flex align-items-center">
                                    <i class="bi bi-check-circle-fill me-3" style="color: var(--accent);"></i>
                                    <span class="text-muted">SQLite</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Origem das bibliotecas, frameworks e recursos externos -->
                <div class="card border-0 shadow-sm p-4 p-md-5 mb-4 animate-on-scroll animate-delay-4" style="background: var(--bg-cream);">
                    <div class="text-center mb-4">
                        <i class="bi bi-box-arrow-up-right" style="font-size: 2.5rem; color: var(--accent);"></i>
                        <h3 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Bibliotecas, Frameworks e Recursos Externos</h3>
                    </div>

                    <ul class="list-unstyled text-muted mb-0">
                        <li class="mb-3">
                            <strong>Bootstrap 5:</strong>
                            framework CSS utilizado para auxiliar a construção da interface gráfica e a responsividade do website.
                            Obtido através do website oficial:
                            <a href="https://getbootstrap.com/" target="_blank" rel="noopener" style="color: var(--accent);">getbootstrap.com</a>.
                        </li>

                        <li class="mb-3">
                            <strong>Bootstrap Icons:</strong>
                            biblioteca de ícones utilizada nos elementos visuais da interface.
                            Obtida através do website oficial:
                            <a href="https://icons.getbootstrap.com/" target="_blank" rel="noopener" style="color: var(--accent);">icons.getbootstrap.com</a>.
                        </li>

                        <li class="mb-3">
                            <strong>Google Fonts:</strong>
                            serviço utilizado para carregar as fontes Great Vibes, Cormorant Garamond e Montserrat.
                            Obtido através de:
                            <a href="https://fonts.google.com/" target="_blank" rel="noopener" style="color: var(--accent);">fonts.google.com</a>.
                        </li>

                        <li class="mb-3">
                            <strong>Unsplash:</strong>
                            plataforma utilizada como origem das imagens demonstrativas do website.
                            Disponível em:
                            <a href="https://unsplash.com/" target="_blank" rel="noopener" style="color: var(--accent);">unsplash.com</a>.
                        </li>

                        <li class="mb-3">
                            <strong>SignalR CDN:</strong>
                            cliente JavaScript do SignalR carregado através da CDN cdnjs.
                            Disponível em:
                            <a href="https://cdnjs.com/libraries/microsoft-signalr" target="_blank" rel="noopener" style="color: var(--accent);">cdnjs.com/libraries/microsoft-signalr</a>.
                        </li>

                        <li class="mb-3">
                            <strong>Microsoft Learn:</strong>
                            documentação consultada para a implementação de funcionalidades relacionadas com ASP.NET Core, Entity Framework Core, Identity, SignalR e Razor Pages.
                            Disponível em:
                            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" rel="noopener" style="color: var(--accent);">learn.microsoft.com/aspnet/core</a>.
                        </li>

                        <li class="mb-3">
                            <strong>NuGet:</strong>
                            origem de pacotes utilizados no projeto, como Entity Framework Core e Microsoft.AspNetCore.Authentication.JwtBearer.
                            Disponível em:
                            <a href="https://www.nuget.org/" target="_blank" rel="noopener" style="color: var(--accent);">nuget.org</a>.
                        </li>

                        <li>
                            <strong>Código adaptado:</strong>
                            algumas soluções técnicas foram adaptadas com base em documentação pública, nomeadamente exemplos de SignalR,
                            inicialização de dados e tratamento de ciclos em JSON.
                            As respetivas referências encontram-se também comentadas junto do código onde foram utilizadas.
                        </li>
                    </ul>
                </div>

                <!-- Tipografia -->
                <div class="card border-0 shadow-sm p-4 p-md-5 mb-4 animate-on-scroll animate-delay-1" style="background: var(--bg-cream);">
                    <div class="text-center mb-4">
                        <i class="bi bi-fonts" style="font-size: 2.5rem; color: var(--accent);"></i>
                        <h3 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Tipografia</h3>
                    </div>
                    <ul class="list-unstyled text-center">
                        <li class="mb-3">
                            <span class="script-font" style="font-size: 2rem;">Great Vibes</span>
                            <p class="text-muted small mb-0">Títulos decorativos</p>
                        </li>
                        <li class="mb-3">
                            <span style="font-family: 'Cormorant Garamond', serif; font-size: 1.5rem;">Cormorant Garamond</span>
                            <p class="text-muted small mb-0">Títulos e subtítulos</p>
                        </li>
                        <li>
                            <span style="font-family: 'Montserrat', sans-serif; font-size: 1rem;">Montserrat</span>
                            <p class="text-muted small mb-0">Corpo de texto</p>
                        </li>
                    </ul>
                </div>

                <!-- Imagens -->
                <div class="card border-0 shadow-sm p-4 p-md-5 mb-4 animate-on-scroll animate-delay-2" style="background: var(--bg-cream);">
                    <div class="text-center mb-4">
                        <i class="bi bi-image" style="font-size: 2.5rem; color: var(--accent);"></i>
                        <h3 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Imagens</h3>
                    </div>
                    <p class="text-muted text-center mb-0">
                        As fotografias apresentadas neste website são para fins demonstrativos e foram obtidas através do
                        <a href="https://unsplash.com" target="_blank" rel="noopener" style="color: var(--accent);">Unsplash</a>,
                        uma plataforma de fotografias gratuitas de alta qualidade. Agradecemos a todos os fotógrafos
                        que partilham o seu trabalho.
                    </p>
                </div>

                <!-- Desenvolvimento -->
                <div class="card border-0 shadow-sm p-4 p-md-5 mb-4 animate-on-scroll animate-delay-7" style="background: var(--bg-cream);">
                    <div class="text-center mb-4">
                        <i class="bi bi-laptop" style="font-size: 2.5rem; color: var(--accent);"></i>
                        <h3 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Desenvolvimento do Projeto</h3>
                    </div>

                    <p class="text-muted text-center">
                        Este website foi desenvolvido como projeto académico da unidade curricular de Desenvolvimento Web,
                        demonstrando capacidades de desenvolvimento web full-stack com ASP.NET Core.
                    </p>

                    <p class="text-muted text-center mb-0">
                        A aplicação inclui autenticação, autorização, interação com base de dados, operações CRUD,
                        API REST e comunicação em tempo real com SignalR.
                    </p>
                </div>

                <!-- Direitos de autor -->
                <div class="card border-0 shadow-sm p-4 p-md-5 animate-on-scroll animate-delay-8" style="background: var(--bg-cream);">
                    <div class="text-center mb-4">
                        <i class="bi bi-c-circle" style="font-size: 2.5rem; color: var(--accent);"></i>
                        <h3 class="mt-3" style="font-family: 'Cormorant Garamond', serif;">Direitos de Autor</h3>
                    </div>

                    <p class="text-muted text-center mb-0">
                        &copy; @DateTime.Now.Year Fstudio Wedding Photography. Todos os direitos reservados.
                        Este é um projeto académico fictício. Qualquer semelhança com empresas ou pessoas reais
                        é mera coincidência.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- Back to Home -->
<section class="section section-cream text-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 animate-on-scroll">
                <p class="section-subtitle">Obrigado</p>
                <h3 style="font-family: 'Cormorant Garamond', serif;">Por Visitar</h3>
                <div class="mt-4">
                    <a asp-page="/Index" class="btn btn-artistic">Voltar ao Início</a>
                </div>
            </div>
        </div>
    </div>
</section>
